# ============================================================================
# ZeroPoint Configuration
# ============================================================================
#
# Generated by: zp secure
# Location:     ~/ZeroPoint/config.toml
# Reconfigure:  zp secure --wizard
#
# This file controls how ZeroPoint governs your compute space.
# Changes take effect immediately — no restart needed.
# ============================================================================

# --- Shell Governance ---
[shell]
# Whether the shell preexec hook is active
enabled = true

# Which shells have hooks installed
# Values: ["zsh"], ["bash"], ["zsh", "bash"]
shells = ["{{PRIMARY_SHELL}}"]

# Governance posture
#   permissive — log everything, block nothing (observation mode)
#   balanced   — warn on risky ops, block critical threats (recommended)
#   strict     — require approval for anything beyond the safe list
posture = "balanced"

# Actor mode for shell commands
#   human      — most trusted, warn on high-risk
#   supervised — moderate trust, block high-risk without approval
#   locked     — agent-level restrictions, block high-risk outright
actor = "human"

# --- AI Tool Wrapping ---
[ai_tools]
# Claude Code integration method
#   mcp      — MCP governance server (intercepts tool calls)
#   wrapper  — PATH shim (wraps the binary)
#   disabled — no wrapping
claude_code = "{{CLAUDE_CODE_METHOD}}"

# Cursor integration
#   wrapper  — PATH shim
#   disabled — no wrapping
cursor = "{{CURSOR_METHOD}}"

# Additional tools (populated by zp secure discovery)
# Format: tool_name = "wrapper" | "disabled"
# aider = "wrapper"
# copilot = "wrapper"

# --- Filesystem Monitoring ---
[filesystem]
# Whether filesystem watchers are active
enabled = true

# Directories to monitor for unauthorized access
# Each produces a receipt on any read/write/chmod event
watch_dirs = [
  "~/.ssh",
  "~/.aws",
  "~/.gnupg",
]

# Additional directories (uncomment or add as needed)
# watch_dirs_extra = [
#   "~/.config/gcloud",
#   "~/.azure",
#   "~/.docker",
#   "~/.kube",
# ]

# Generate a receipt for every access event
receipt_on_access = true

# --- Docker Integration ---
[docker]
# Whether Docker container actions produce receipts
enabled = {{DOCKER_ENABLED}}

# --- Network & API (opt-in) ---
[network]
# Lightweight local proxy for outbound API calls
# Start with: zp proxy start
proxy_enabled = false
proxy_port = 8888

# Outbound connection monitoring for wrapped processes
# Start with: zp net watch
monitor_enabled = false

# DNS query logging (privacy-sensitive — off by default)
dns_logging = false

# --- Guard Behavior ---
[guard]
# Cache approval decisions within a session
# "always" approvals persist until shell exits
cache_approvals = true

# What happens when the guard binary is missing or crashes
#   open   — allow the command (don't break the user's shell)
#   closed — deny the command (maximum safety, may disrupt workflow)
fail_mode = "open"

# --- Advanced ---
[advanced]
# Data directory for receipts, audit chain, and state
data_dir = "~/ZeroPoint/data"

# Log level for ZeroPoint components
# Values: error, warn, info, debug, trace
log_level = "info"

# Server port (for dashboard and API)
server_port = 3000
server_bind = "127.0.0.1"
