#!/bin/sh
#
# ZeroPoint Network Sentinel - Entware systemd-style init script
# Location: /opt/etc/init.d/S99zp-sentinel
# Enables automatic startup after router reboot
#

### BEGIN INIT INFO
# Provides:          zp-sentinel
# Required-Start:    networking dnsmasq
# Required-Stop:
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: ZeroPoint Network Sentinel
# Description:       Governance-based network access control for ASUS Merlin
### END INIT INFO

PATH=/opt/sbin:/opt/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
DESC="ZeroPoint Network Sentinel"
NAME="zp-sentinel"
DAEMON="/opt/bin/python3"
SCRIPT_DIR="/opt/etc/zp-sentinel"
MAIN_SCRIPT="$SCRIPT_DIR/zp_sentinel/main.py"
CONFIG_FILE="/opt/etc/zp-sentinel.toml"
PID_FILE="/opt/var/run/zp-sentinel.pid"
LOG_FILE="/opt/var/log/zp-sentinel.log"
USER="root"

# Export Python path
export PYTHONPATH="/opt/etc/zp-sentinel"

# Create necessary directories
mkdir -p /opt/var/run
mkdir -p /opt/var/log
mkdir -p /opt/var/zp-sentinel
mkdir -p /opt/var/cache/zp-sentinel

# Verify config file exists
if [ ! -f "$CONFIG_FILE" ]; then
    echo "ERROR: Config file not found: $CONFIG_FILE"
    exit 1
fi

case "$1" in
    start)
        echo "Starting $DESC"

        # Check if already running
        if [ -f "$PID_FILE" ]; then
            OLD_PID=$(cat "$PID_FILE")
            if kill -0 "$OLD_PID" 2>/dev/null; then
                echo "$DESC is already running (PID: $OLD_PID)"
                exit 0
            else
                # Stale PID file
                rm -f "$PID_FILE"
            fi
        fi

        # Start the service
        nohup "$DAEMON" -B -m zp_sentinel.main -c "$CONFIG_FILE" monitor > "$LOG_FILE" 2>&1 &

        NEW_PID=$!
        echo "$NEW_PID" > "$PID_FILE"
        echo "Started $DESC (PID: $NEW_PID)"
        sleep 1

        # Verify it started
        if ! kill -0 "$NEW_PID" 2>/dev/null; then
            echo "ERROR: Failed to start $DESC"
            rm -f "$PID_FILE"
            exit 1
        fi

        exit 0
        ;;

    stop)
        echo "Stopping $DESC"

        if [ ! -f "$PID_FILE" ]; then
            echo "$DESC is not running"
            exit 0
        fi

        PID=$(cat "$PID_FILE")

        if kill -0 "$PID" 2>/dev/null; then
            echo "Killing process $PID"
            kill -TERM "$PID"

            # Wait for graceful shutdown (up to 10 seconds)
            COUNT=0
            while kill -0 "$PID" 2>/dev/null && [ $COUNT -lt 10 ]; do
                sleep 1
                COUNT=$((COUNT + 1))
            done

            # Force kill if necessary
            if kill -0 "$PID" 2>/dev/null; then
                echo "Force killing $DESC"
                kill -9 "$PID"
            fi
        fi

        rm -f "$PID_FILE"
        echo "Stopped $DESC"
        exit 0
        ;;

    restart|force-reload)
        echo "Restarting $DESC"
        $0 stop
        sleep 1
        $0 start
        exit $?
        ;;

    status)
        if [ -f "$PID_FILE" ]; then
            PID=$(cat "$PID_FILE")
            if kill -0 "$PID" 2>/dev/null; then
                echo "$DESC is running (PID: $PID)"
                exit 0
            else
                echo "$DESC is not running (stale PID: $PID)"
                exit 1
            fi
        else
            echo "$DESC is not running"
            exit 1
        fi
        ;;

    *)
        echo "Usage: $0 {start|stop|restart|force-reload|status}"
        exit 1
        ;;
esac

exit 0
